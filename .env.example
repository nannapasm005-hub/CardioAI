# คัดลอกไฟล์นี้เป็น .env แล้วใส่คีย์จริงของคุณ (อย่า commit .env)
#   cp .env.example .env

# คีย์ Typhoon API (สมัครที่ https://opentyphoon.ai) — ห้ามฮาร์ดโค้ดในโค้ด
TYPHOON_API_KEY=your_key_here

# (ทางเลือก) เปลี่ยนรุ่นโมเดลได้ ถ้าไม่ตั้งจะใช้ค่า default
# TYPHOON_MODEL=typhoon-v2.5-30b-a3b-instruct

# (ทางเลือก) ขั้นที่ 6 — โดเมนที่อนุญาตให้เรียก API คั่นด้วย comma เช่น https://cardioai.example.com
# ALLOWED_ORIGINS=*
